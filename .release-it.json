{
  "git": {
    "commitMessage": "chore(release): release v${version}",
    "tagName": "v${version}",
    "push": true,
    "requireBranch": "main",
    "requireUpstream": false,
    "requireCleanWorkingDir": false
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": true,
    "releaseName": "One Dark Pro Custom v${version}",
    "releaseNotes": "See [CHANGELOG.md](${repo.repository}/blob/main/CHANGELOG.md#${latestTag}) for details.",
    "assets": [
      "*.vsix"
    ]
  },
  "hooks": {
    "before:init": [
      "echo 'Starting release process for One Dark Pro Custom...'",
      "echo 'Verifying theme file exists...'",
      "git pull"
    ],
    "before:bump": [
      "echo 'Running pre-release checks...'"
    ],
    "after:bump": [
      "echo '📦 Version bumped to ${version}, packaging extension...'",
      "pnpm package"
    ],
    "after:git:release": [
      "echo 'Publishing to VS Code Marketplace...'",
      "pnpm exec vsce publish -p $VSCE_PAT"
    ],
    "after:release": [
      "echo '🎉 Successfully released One Dark Pro Custom v${version}!'"
    ]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "header": "# Changelog\n\nAll notable changes to the One Dark Pro Custom theme will be documented in this file.\n\nThe format is based on [Keep a Changelog](https://keepachangelog.com/en/1.0.0/),\nand this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).\n",
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {
            "type": "feat",
            "section": "✨ Features"
          },
          {
            "type": "fix",
            "section": "🐛 Bug Fixes"
          },
          {
            "type": "chore",
            "hidden": true
          },
          {
            "type": "docs",
            "section": "📚 Documentation"
          },
          {
            "type": "style",
            "section": "💎 Style Changes"
          },
          {
            "type": "refactor",
            "section": "♻️ Code Refactoring"
          },
          {
            "type": "perf",
            "section": "⚡ Performance Improvements"
          },
          {
            "type": "test",
            "hidden": true
          }
        ]
      }
    }
  }
}
